  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "5527125334398604413"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "metadata": {
        "description": "Name of the environment that can be used as part of naming resource convention"
      }
    },
    "publisherEmail": {
      "type": "string",
      "metadata": {
        "description": "The publisher email"
      }
    },
    "publisherName": {
      "type": "string",
      "metadata": {
        "description": "The publisher name"
      }
    },
    "location": {
      "type": "string",
      "allowedValues": [
        "australiaeast",
        "canadacentral",
        "centralus",
        "eastus",
        "eastus2",
        "francecentral",
        "northeurope",
        "southcentralus",
        "switzerlandnorth",
        "westeurope",
        "westus2",
        "westus3"
      ],
      "minLength": 1,
      "metadata": {
        "description": "Primary location for all resources"
      }
    },
    "apimSku": {
      "type": "string",
      "allowedValues": [
        "Basicv2",
        "Standardv2",
        "Premiumv2"
      ],
      "metadata": {
        "description": "The SKU of the APIM instance"
      }
    }
  },
